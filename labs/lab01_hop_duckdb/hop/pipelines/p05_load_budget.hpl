<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>p05_load_budget</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Load staging.budget into warehouse.fact_budget using Hop native transforms.</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters/>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2026/06/17 00:00:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2026/06/17 00:00:00.000</modified_date>
  </info>
  <notepads/>
  <order>
    <!-- TRUNCATE first (plumbing) -->
    <hop><from>Truncate fact_budget</from><to>Read staging.budget</to><enabled>Y</enabled></hop>

    <!-- Main flow: budget → lookup category_name → lookup channel_key → rename month → write -->
    <hop><from>Read staging.budget</from><to>Lookup category name</to><enabled>Y</enabled></hop>
    <hop><from>Read staging.categories</from><to>Lookup category name</to><enabled>Y</enabled></hop>
    <hop><from>Lookup category name</from><to>Lookup channel key</to><enabled>Y</enabled></hop>
    <hop><from>Read warehouse.dim_channel</from><to>Lookup channel key</to><enabled>Y</enabled></hop>
    <hop><from>Lookup channel key</from><to>Select fact_budget fields</to><enabled>Y</enabled></hop>
    <hop><from>Select fact_budget fields</from><to>Write warehouse.fact_budget</to><enabled>Y</enabled></hop>
  </order>

  <!-- TRUNCATE fact_budget before load (plumbing — allowed) -->
  <transform>
    <name>Truncate fact_budget</name>
    <type>ExecSql</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <connection>DuckDB_Lab1</connection>
    <execute_each_row>N</execute_each_row>
    <single_statement>Y</single_statement>
    <replace_variables>N</replace_variables>
    <sql>TRUNCATE warehouse.fact_budget;</sql>
    <attributes/>
    <GUI><xloc>80</xloc><yloc>80</yloc></GUI>
  </transform>

  <!-- Read all budget rows from staging -->
  <transform>
    <name>Read staging.budget</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <connection>DuckDB_Lab1</connection>
    <sql>SELECT budget_id, year, month, category_id, channel, budget_amount, budget_qty FROM staging.budget</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <attributes/>
    <GUI><xloc>280</xloc><yloc>80</yloc></GUI>
  </transform>

  <!-- Lookup stream: categories (read into memory) -->
  <transform>
    <name>Read staging.categories</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <connection>DuckDB_Lab1</connection>
    <sql>SELECT category_id, category_name FROM staging.categories</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <attributes/>
    <GUI><xloc>480</xloc><yloc>0</yloc></GUI>
  </transform>

  <!-- StreamLookup: resolve category_name from staging.categories -->
  <transform>
    <name>Lookup category name</name>
    <type>StreamLookup</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <from>Read staging.categories</from>
    <input_sorted>N</input_sorted>
    <preserve_memory>Y</preserve_memory>
    <sorted_list>N</sorted_list>
    <integer_pair>N</integer_pair>
    <lookup>
      <key>
        <name>category_id</name>
        <field>category_id</field>
      </key>
      <value>
        <name>category_name</name>
        <rename>category_name</rename>
        <default/>
        <type>String</type>
      </value>
    </lookup>
    <attributes/>
    <GUI><xloc>480</xloc><yloc>80</yloc></GUI>
  </transform>

  <!-- Lookup stream: dim_channel (read into memory) -->
  <transform>
    <name>Read warehouse.dim_channel</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <connection>DuckDB_Lab1</connection>
    <sql>SELECT channel_name AS channel, channel_key FROM warehouse.dim_channel</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <attributes/>
    <GUI><xloc>680</xloc><yloc>0</yloc></GUI>
  </transform>

  <!-- StreamLookup: resolve channel_key from warehouse.dim_channel -->
  <transform>
    <name>Lookup channel key</name>
    <type>StreamLookup</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <from>Read warehouse.dim_channel</from>
    <input_sorted>N</input_sorted>
    <preserve_memory>Y</preserve_memory>
    <sorted_list>N</sorted_list>
    <integer_pair>N</integer_pair>
    <lookup>
      <key>
        <name>channel</name>
        <field>channel</field>
      </key>
      <value>
        <name>channel_key</name>
        <rename>channel_key</rename>
        <default/>
        <type>Integer</type>
      </value>
    </lookup>
    <attributes/>
    <GUI><xloc>680</xloc><yloc>80</yloc></GUI>
  </transform>

  <!-- SelectValues: rename month → month_num, keep only warehouse columns -->
  <transform>
    <name>Select fact_budget fields</name>
    <type>SelectValues</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <fields>
      <field><name>budget_id</name><rename>budget_id</rename><length>-2</length><precision>-2</precision></field>
      <field><name>year</name><rename>year</rename><length>-2</length><precision>-2</precision></field>
      <field><name>month</name><rename>month_num</rename><length>-2</length><precision>-2</precision></field>
      <field><name>category_id</name><rename>category_id</rename><length>-2</length><precision>-2</precision></field>
      <field><name>category_name</name><rename>category_name</rename><length>-2</length><precision>-2</precision></field>
      <field><name>channel_key</name><rename>channel_key</rename><length>-2</length><precision>-2</precision></field>
      <field><name>budget_amount</name><rename>budget_amount</rename><length>-2</length><precision>-2</precision></field>
      <field><name>budget_qty</name><rename>budget_qty</rename><length>-2</length><precision>-2</precision></field>
    </fields>
    <select_unspecified>N</select_unspecified>
    <attributes/>
    <GUI><xloc>880</xloc><yloc>80</yloc></GUI>
  </transform>

  <!-- TableOutput: write to warehouse.fact_budget (truncate=N, handled by ExecSql above) -->
  <transform>
    <name>Write warehouse.fact_budget</name>
    <type>TableOutput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <commit>1000</commit>
    <connection>DuckDB_Lab1</connection>
    <fields/>
    <ignore_errors>N</ignore_errors>
    <only_when_have_rows>N</only_when_have_rows>
    <partitioning_daily>N</partitioning_daily>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_monthly>Y</partitioning_monthly>
    <return_keys>N</return_keys>
    <schema>warehouse</schema>
    <specify_fields>N</specify_fields>
    <table>fact_budget</table>
    <tablename_in_field>N</tablename_in_field>
    <tablename_in_table>Y</tablename_in_table>
    <truncate>N</truncate>
    <use_batch>Y</use_batch>
    <attributes/>
    <GUI><xloc>1080</xloc><yloc>80</yloc></GUI>
  </transform>

  <transform_error_handling/>
  <attributes/>
</pipeline>
