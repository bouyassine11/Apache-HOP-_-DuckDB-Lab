<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>p04_incremental_load</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Load April 2025 batch into staging with watermark filtering and dedup using Hop native transforms.</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters/>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2026/06/17 00:00:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2026/06/17 00:00:00.000</modified_date>
  </info>
  <notepads/>
  <order>
    <!-- orders_april: CSVInput → SelectValues → FilterRows(date > watermark) → StreamLookup(dedup) → FilterRows(keep misses) → TableOutput -->
    <hop><from>Read orders_april</from><to>Filter new orders</to><enabled>Y</enabled></hop>
    <hop><from>Filter new orders</from><to>Dedup orders</to><enabled>Y</enabled></hop>
    <hop><from>Read existing order_ids</from><to>Dedup orders</to><enabled>Y</enabled></hop>
    <hop><from>Dedup orders</from><to>Keep new orders only</to><enabled>Y</enabled></hop>
    <hop><from>Keep new orders only</from><to>Write staging.orders</to><enabled>Y</enabled></hop>

    <!-- order_items_april: CSVInput → StreamLookup(dedup) → FilterRows(keep misses) → TableOutput -->
    <hop><from>Read order_items_april</from><to>Dedup order_items</to><enabled>Y</enabled></hop>
    <hop><from>Read existing order_item_ids</from><to>Dedup order_items</to><enabled>Y</enabled></hop>
    <hop><from>Dedup order_items</from><to>Keep new order_items only</to><enabled>Y</enabled></hop>
    <hop><from>Keep new order_items only</from><to>Write staging.order_items</to><enabled>Y</enabled></hop>

    <!-- payments_april: CSVInput → FilterRows(date > watermark) → StreamLookup(dedup) → FilterRows(keep misses) → TableOutput -->
    <hop><from>Read payments_april</from><to>Filter new payments</to><enabled>Y</enabled></hop>
    <hop><from>Filter new payments</from><to>Dedup payments</to><enabled>Y</enabled></hop>
    <hop><from>Read existing payment_ids</from><to>Dedup payments</to><enabled>Y</enabled></hop>
    <hop><from>Dedup payments</from><to>Keep new payments only</to><enabled>Y</enabled></hop>
    <hop><from>Keep new payments only</from><to>Write staging.payments</to><enabled>Y</enabled></hop>

    <!-- watermark update (ExecSql — allowed for control table) -->
    <hop><from>Update watermarks</from><to>Done</to><enabled>Y</enabled></hop>
  </order>

  <!-- ══════════════════════════════════════════════════════════
       ORDERS_APRIL — y=80
       Read as String dates to avoid Hop Date comparison metadata issues
       ══════════════════════════════════════════════════════════ -->
  <transform>
    <name>Read orders_april</name>
    <type>CSVInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <filename>${PROJECT_HOME}/data/raw/orders_april.csv</filename>
    <filename_field/>
    <rownum_field/>
    <include_filename>N</include_filename>
    <separator>,</separator>
    <enclosure>"</enclosure>
    <header>Y</header>
    <buffer_size>50000</buffer_size>
    <schemaDefinition/>
    <lazy_conversion>N</lazy_conversion>
    <add_filename_result>N</add_filename_result>
    <parallel>N</parallel>
    <newline_possible>N</newline_possible>
    <encoding/>
    <fields>
      <field><name>order_id</name><type>Integer</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type></field>
      <field><name>customer_id</name><type>Integer</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type></field>
      <field><name>order_date</name><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type></field>
      <field><name>channel</name><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type></field>
      <field><name>order_status</name><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type></field>
      <field><name>city</name><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>both</trim_type></field>
    </fields>
    <attributes/>
    <GUI><xloc>80</xloc><yloc>80</yloc></GUI>
  </transform>

  <!-- FilterRows: keep order_date > '2025-03-21' (String comparison works for yyyy-MM-dd) -->
  <transform>
    <name>Filter new orders</name>
    <type>FilterRows</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <compare>
      <condition>
        <negated>N</negated>
        <conditions>
          <condition>
            <negated>N</negated>
            <leftvalue>order_date</leftvalue>
            <function>&gt;</function>
            <rightvalue/>
            <value>
              <name>constant</name>
              <type>String</type>
              <text>2025-03-21</text>
              <length>-1</length>
              <precision>-1</precision>
              <isnull>N</isnull>
              <mask/>
            </value>
          </condition>
        </conditions>
      </condition>
    </compare>
    <send_false_to/>
    <send_true_to>Dedup orders</send_true_to>
    <attributes/>
    <GUI><xloc>300</xloc><yloc>80</yloc></GUI>
  </transform>

  <!-- Read existing order_ids into memory for StreamLookup dedup -->
  <transform>
    <name>Read existing order_ids</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <connection>DuckDB_Lab1</connection>
    <sql>SELECT CAST(order_id AS INTEGER) AS order_id FROM staging.orders</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <attributes/>
    <GUI><xloc>300</xloc><yloc>0</yloc></GUI>
  </transform>

  <!-- StreamLookup: join on order_id (both as String to avoid type mismatch) -->
  <transform>
    <name>Dedup orders</name>
    <type>StreamLookup</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <from>Read existing order_ids</from>
    <input_sorted>N</input_sorted>
    <preserve_memory>Y</preserve_memory>
    <sorted_list>N</sorted_list>
    <integer_pair>N</integer_pair>
    <lookup>
      <key>
        <name>order_id</name>
        <field>order_id</field>
      </key>
      <value>
        <name>order_id</name>
        <rename>found_order_id</rename>
        <default/>
        <type>Integer</type>
      </value>
    </lookup>
    <attributes/>
    <GUI><xloc>500</xloc><yloc>80</yloc></GUI>
  </transform>

  <!-- Keep only rows where found_order_id IS NULL (not already in staging) -->
  <transform>
    <name>Keep new orders only</name>
    <type>FilterRows</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <compare>
      <condition>
        <negated>N</negated>
        <conditions>
          <condition>
            <negated>N</negated>
            <leftvalue>found_order_id</leftvalue>
            <function>IS NULL</function>
            <rightvalue/>
          </condition>
        </conditions>
      </condition>
    </compare>
    <send_false_to/>
    <send_true_to>Write staging.orders</send_true_to>
    <attributes/>
    <GUI><xloc>700</xloc><yloc>80</yloc></GUI>
  </transform>

  <transform>
    <name>Write staging.orders</name>
    <type>TableOutput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <commit>1000</commit>
    <connection>DuckDB_Lab1</connection>
    <fields>
      <field><column_name>order_id</column_name><stream_name>order_id</stream_name></field>
      <field><column_name>customer_id</column_name><stream_name>customer_id</stream_name></field>
      <field><column_name>order_date</column_name><stream_name>order_date</stream_name></field>
      <field><column_name>channel</column_name><stream_name>channel</stream_name></field>
      <field><column_name>order_status</column_name><stream_name>order_status</stream_name></field>
      <field><column_name>city</column_name><stream_name>city</stream_name></field>
    </fields>
    <ignore_errors>N</ignore_errors>
    <only_when_have_rows>N</only_when_have_rows>
    <partitioning_daily>N</partitioning_daily>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_monthly>Y</partitioning_monthly>
    <return_keys>N</return_keys>
    <schema>staging</schema>
    <specify_fields>Y</specify_fields>
    <table>orders</table>
    <tablename_in_field>N</tablename_in_field>
    <tablename_in_table>Y</tablename_in_table>
    <truncate>N</truncate>
    <use_batch>Y</use_batch>
    <attributes/>
    <GUI><xloc>900</xloc><yloc>80</yloc></GUI>
  </transform>

  <!-- ══════════════════════════════════════════════════════════
       ORDER_ITEMS_APRIL — y=280 (no date filter needed)
       ══════════════════════════════════════════════════════════ -->
  <transform>
    <name>Read order_items_april</name>
    <type>CSVInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <filename>${PROJECT_HOME}/data/raw/order_items_april.csv</filename>
    <filename_field/>
    <rownum_field/>
    <include_filename>N</include_filename>
    <separator>,</separator>
    <enclosure>"</enclosure>
    <header>Y</header>
    <buffer_size>50000</buffer_size>
    <schemaDefinition/>
    <lazy_conversion>N</lazy_conversion>
    <add_filename_result>N</add_filename_result>
    <parallel>N</parallel>
    <newline_possible>N</newline_possible>
    <encoding/>
    <fields>
      <field><name>order_item_id</name><type>Integer</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type></field>
      <field><name>order_id</name><type>Integer</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type></field>
      <field><name>product_id</name><type>Integer</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type></field>
      <field><name>quantity</name><type>Integer</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type></field>
      <field><name>unit_price</name><type>BigNumber</type><format/><currency/><decimal>.</decimal><group/><length>-1</length><precision>2</precision><trim_type>none</trim_type></field>
      <field><name>discount_amount</name><type>BigNumber</type><format/><currency/><decimal>.</decimal><group/><length>-1</length><precision>2</precision><trim_type>none</trim_type></field>
    </fields>
    <attributes/>
    <GUI><xloc>80</xloc><yloc>280</yloc></GUI>
  </transform>

  <transform>
    <name>Read existing order_item_ids</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <connection>DuckDB_Lab1</connection>
    <sql>SELECT order_item_id FROM staging.order_items</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <attributes/>
    <GUI><xloc>280</xloc><yloc>200</yloc></GUI>
  </transform>

  <transform>
    <name>Dedup order_items</name>
    <type>StreamLookup</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <from>Read existing order_item_ids</from>
    <input_sorted>N</input_sorted>
    <preserve_memory>Y</preserve_memory>
    <sorted_list>N</sorted_list>
    <integer_pair>N</integer_pair>
    <lookup>
      <key>
        <name>order_item_id</name>
        <field>order_item_id</field>
      </key>
      <value>
        <name>order_item_id</name>
        <rename>found_order_item_id</rename>
        <default/>
        <type>Integer</type>
      </value>
    </lookup>
    <attributes/>
    <GUI><xloc>480</xloc><yloc>280</yloc></GUI>
  </transform>

  <transform>
    <name>Keep new order_items only</name>
    <type>FilterRows</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <compare>
      <condition>
        <negated>N</negated>
        <conditions>
          <condition>
            <negated>N</negated>
            <leftvalue>found_order_item_id</leftvalue>
            <function>IS NULL</function>
            <rightvalue/>
          </condition>
        </conditions>
      </condition>
    </compare>
    <send_false_to/>
    <send_true_to>Write staging.order_items</send_true_to>
    <attributes/>
    <GUI><xloc>680</xloc><yloc>280</yloc></GUI>
  </transform>

  <transform>
    <name>Write staging.order_items</name>
    <type>TableOutput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <commit>1000</commit>
    <connection>DuckDB_Lab1</connection>
    <fields>
      <field><column_name>order_item_id</column_name><stream_name>order_item_id</stream_name></field>
      <field><column_name>order_id</column_name><stream_name>order_id</stream_name></field>
      <field><column_name>product_id</column_name><stream_name>product_id</stream_name></field>
      <field><column_name>quantity</column_name><stream_name>quantity</stream_name></field>
      <field><column_name>unit_price</column_name><stream_name>unit_price</stream_name></field>
      <field><column_name>discount_amount</column_name><stream_name>discount_amount</stream_name></field>
    </fields>
    <ignore_errors>N</ignore_errors>
    <only_when_have_rows>N</only_when_have_rows>
    <partitioning_daily>N</partitioning_daily>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_monthly>Y</partitioning_monthly>
    <return_keys>N</return_keys>
    <schema>staging</schema>
    <specify_fields>Y</specify_fields>
    <table>order_items</table>
    <tablename_in_field>N</tablename_in_field>
    <tablename_in_table>Y</tablename_in_table>
    <truncate>N</truncate>
    <use_batch>Y</use_batch>
    <attributes/>
    <GUI><xloc>880</xloc><yloc>280</yloc></GUI>
  </transform>

  <!-- ══════════════════════════════════════════════════════════
       PAYMENTS_APRIL — y=480
       ══════════════════════════════════════════════════════════ -->
  <transform>
    <name>Read payments_april</name>
    <type>CSVInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <filename>${PROJECT_HOME}/data/raw/payments_april.csv</filename>
    <filename_field/>
    <rownum_field/>
    <include_filename>N</include_filename>
    <separator>,</separator>
    <enclosure>"</enclosure>
    <header>Y</header>
    <buffer_size>50000</buffer_size>
    <schemaDefinition/>
    <lazy_conversion>N</lazy_conversion>
    <add_filename_result>N</add_filename_result>
    <parallel>N</parallel>
    <newline_possible>N</newline_possible>
    <encoding/>
    <fields>
      <field><name>payment_id</name><type>Integer</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type></field>
      <field><name>order_id</name><type>Integer</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type></field>
      <field><name>payment_date</name><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type></field>
      <field><name>payment_method</name><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type></field>
      <field><name>payment_status</name><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>none</trim_type></field>
      <field><name>amount</name><type>BigNumber</type><format/><currency/><decimal>.</decimal><group/><length>-1</length><precision>2</precision><trim_type>none</trim_type></field>
    </fields>
    <attributes/>
    <GUI><xloc>80</xloc><yloc>480</yloc></GUI>
  </transform>

  <transform>
    <name>Filter new payments</name>
    <type>FilterRows</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <compare>
      <condition>
        <negated>N</negated>
        <conditions>
          <condition>
            <negated>N</negated>
            <leftvalue>payment_date</leftvalue>
            <function>&gt;</function>
            <rightvalue/>
            <value>
              <name>constant</name>
              <type>String</type>
              <text>2025-03-21</text>
              <length>-1</length>
              <precision>-1</precision>
              <isnull>N</isnull>
              <mask/>
            </value>
          </condition>
        </conditions>
      </condition>
    </compare>
    <send_false_to/>
    <send_true_to>Dedup payments</send_true_to>
    <attributes/>
    <GUI><xloc>280</xloc><yloc>480</yloc></GUI>
  </transform>

  <transform>
    <name>Read existing payment_ids</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <connection>DuckDB_Lab1</connection>
    <sql>SELECT payment_id FROM staging.payments</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <attributes/>
    <GUI><xloc>280</xloc><yloc>400</yloc></GUI>
  </transform>

  <transform>
    <name>Dedup payments</name>
    <type>StreamLookup</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <from>Read existing payment_ids</from>
    <input_sorted>N</input_sorted>
    <preserve_memory>Y</preserve_memory>
    <sorted_list>N</sorted_list>
    <integer_pair>N</integer_pair>
    <lookup>
      <key>
        <name>payment_id</name>
        <field>payment_id</field>
      </key>
      <value>
        <name>payment_id</name>
        <rename>found_payment_id</rename>
        <default/>
        <type>Integer</type>
      </value>
    </lookup>
    <attributes/>
    <GUI><xloc>480</xloc><yloc>480</yloc></GUI>
  </transform>

  <transform>
    <name>Keep new payments only</name>
    <type>FilterRows</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <compare>
      <condition>
        <negated>N</negated>
        <conditions>
          <condition>
            <negated>N</negated>
            <leftvalue>found_payment_id</leftvalue>
            <function>IS NULL</function>
            <rightvalue/>
          </condition>
        </conditions>
      </condition>
    </compare>
    <send_false_to/>
    <send_true_to>Write staging.payments</send_true_to>
    <attributes/>
    <GUI><xloc>680</xloc><yloc>480</yloc></GUI>
  </transform>

  <transform>
    <name>Write staging.payments</name>
    <type>TableOutput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <commit>1000</commit>
    <connection>DuckDB_Lab1</connection>
    <fields>
      <field><column_name>payment_id</column_name><stream_name>payment_id</stream_name></field>
      <field><column_name>order_id</column_name><stream_name>order_id</stream_name></field>
      <field><column_name>payment_date</column_name><stream_name>payment_date</stream_name></field>
      <field><column_name>payment_method</column_name><stream_name>payment_method</stream_name></field>
      <field><column_name>payment_status</column_name><stream_name>payment_status</stream_name></field>
      <field><column_name>amount</column_name><stream_name>amount</stream_name></field>
    </fields>
    <ignore_errors>N</ignore_errors>
    <only_when_have_rows>N</only_when_have_rows>
    <partitioning_daily>N</partitioning_daily>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_monthly>Y</partitioning_monthly>
    <return_keys>N</return_keys>
    <schema>staging</schema>
    <specify_fields>Y</specify_fields>
    <table>payments</table>
    <tablename_in_field>N</tablename_in_field>
    <tablename_in_table>Y</tablename_in_table>
    <truncate>N</truncate>
    <use_batch>Y</use_batch>
    <attributes/>
    <GUI><xloc>880</xloc><yloc>480</yloc></GUI>
  </transform>

  <!-- ══════════════════════════════════════════════════════════
       UPDATE WATERMARKS — ExecSql (allowed: control table)
       y=680
       ══════════════════════════════════════════════════════════ -->
  <transform>
    <name>Update watermarks</name>
    <type>ExecSql</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <connection>DuckDB_Lab1</connection>
    <execute_each_row>N</execute_each_row>
    <single_statement>N</single_statement>
    <replace_variables>N</replace_variables>
