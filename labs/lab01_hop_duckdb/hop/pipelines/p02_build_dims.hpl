<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>p02_build_dims</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Build warehouse dimensions from staging using Hop native transforms.</description>
    <extended_description/>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters/>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2026/06/17 00:00:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2026/06/17 00:00:00.000</modified_date>
  </info>
  <notepads/>
  <order>
    <!-- dim_date: ExecSql (calendar generation — allowed as plumbing) -->
    <hop><from>Truncate and load dim_date</from><to>Dummy dim_date</to><enabled>Y</enabled></hop>

    <!-- Truncate all dims first (plumbing), then run data flows -->
    <hop><from>Truncate dims</from><to>Read customers</to><enabled>Y</enabled></hop>
    <hop><from>Truncate dims</from><to>Read products</to><enabled>Y</enabled></hop>
    <hop><from>Truncate dims</from><to>Read channels</to><enabled>Y</enabled></hop>

    <!-- dim_customer -->
    <hop><from>Read customers</from><to>Sort customers</to><enabled>Y</enabled></hop>
    <hop><from>Sort customers</from><to>Unique customers</to><enabled>Y</enabled></hop>
    <hop><from>Unique customers</from><to>Filter valid customers</to><enabled>Y</enabled></hop>
    <hop><from>Filter valid customers</from><to>Normalize city</to><enabled>Y</enabled></hop>
    <hop><from>Normalize city</from><to>Default email</to><enabled>Y</enabled></hop>
    <hop><from>Default email</from><to>Add customer_key</to><enabled>Y</enabled></hop>
    <hop><from>Add customer_key</from><to>Select customer fields</to><enabled>Y</enabled></hop>
    <hop><from>Select customer fields</from><to>Write dim_customer</to><enabled>Y</enabled></hop>

    <!-- dim_product -->
    <hop><from>Read products</from><to>Filter valid products</to><enabled>Y</enabled></hop>
    <hop><from>Filter valid products</from><to>Lookup category info</to><enabled>Y</enabled></hop>
    <hop><from>Read categories</from><to>Lookup category info</to><enabled>Y</enabled></hop>
    <hop><from>Lookup category info</from><to>Add product_key</to><enabled>Y</enabled></hop>
    <hop><from>Add product_key</from><to>Select product fields</to><enabled>Y</enabled></hop>
    <hop><from>Select product fields</from><to>Write dim_product</to><enabled>Y</enabled></hop>

    <!-- dim_channel -->
    <hop><from>Read channels</from><to>Map channel_type</to><enabled>Y</enabled></hop>
    <hop><from>Map channel_type</from><to>Add channel_key</to><enabled>Y</enabled></hop>
    <hop><from>Add channel_key</from><to>Select channel fields</to><enabled>Y</enabled></hop>
    <hop><from>Select channel fields</from><to>Write dim_channel</to><enabled>Y</enabled></hop>
  </order>

  <!-- ══════════════════════════════════════════════════════════
       TRUNCATE all dims first (plumbing — allowed by lab rules)
       y=80 col=600
       ══════════════════════════════════════════════════════════ -->
  <transform>
    <name>Truncate dims</name>
    <type>ExecSql</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <connection>DuckDB_Lab1</connection>
    <execute_each_row>N</execute_each_row>
    <single_statement>N</single_statement>
    <replace_variables>N</replace_variables>
    <sql>TRUNCATE warehouse.dim_customer; TRUNCATE warehouse.dim_product; TRUNCATE warehouse.dim_channel;</sql>
    <attributes/>
    <GUI><xloc>600</xloc><yloc>80</yloc></GUI>
  </transform>

  <!-- ══════════════════════════════════════════════════════════
       DIM_DATE — ExecSql (calendar generation, allowed as plumbing)
       y=80
       ══════════════════════════════════════════════════════════ -->
  <transform>
    <name>Truncate and load dim_date</name>
    <type>ExecSql</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <connection>DuckDB_Lab1</connection>
    <execute_each_row>N</execute_each_row>
    <single_statement>N</single_statement>
    <replace_variables>N</replace_variables>
    <sql>TRUNCATE warehouse.dim_date; INSERT INTO warehouse.dim_date (date_key,date_actual,year,quarter,month_num,month_name,day_num,day_name,day_of_week,is_weekend,season) SELECT YEAR(d.dt)*10000+MONTH(d.dt)*100+DAY(d.dt),d.dt,YEAR(d.dt),QUARTER(d.dt),MONTH(d.dt),MONTHNAME(d.dt),DAY(d.dt),DAYNAME(d.dt),DAYOFWEEK(d.dt),DAYOFWEEK(d.dt) IN (0,6),CASE WHEN MONTH(d.dt) IN (12,1,2) THEN 'Winter' WHEN MONTH(d.dt) IN (3,4,5) THEN 'Spring' WHEN MONTH(d.dt) IN (6,7,8) THEN 'Summer' ELSE 'Autumn' END FROM (SELECT UNNEST(GENERATE_SERIES(DATE '2024-01-01',DATE '2026-12-31',INTERVAL '1 day')) AS dt) d;</sql>
    <attributes/>
    <GUI><xloc>160</xloc><yloc>80</yloc></GUI>
  </transform>
  <transform>
    <name>Dummy dim_date</name>
    <type>Dummy</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <attributes/>
    <GUI><xloc>380</xloc><yloc>80</yloc></GUI>
  </transform>

  <!-- ══════════════════════════════════════════════════════════
       DIM_CUSTOMER — Hop native transforms
       y=260
       ══════════════════════════════════════════════════════════ -->
  <transform>
    <name>Read customers</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <connection>DuckDB_Lab1</connection>
    <sql>SELECT customer_id, customer_name, email, UPPER(TRIM(city)) AS city, country, CAST(signup_date AS VARCHAR) AS signup_date, segment FROM staging.customers WHERE customer_id IS NOT NULL AND customer_name IS NOT NULL</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <attributes/>
    <GUI><xloc>80</xloc><yloc>260</yloc></GUI>
  </transform>

  <transform>
    <name>Sort customers</name>
    <type>SortRows</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <directory>${java.io.tmpdir}</directory>
    <prefix>out</prefix>
    <sort_size>1000000</sort_size>
    <free_memory/>
    <compress>N</compress>
    <compress_variable/>
    <unique_rows>N</unique_rows>
    <fields>
      <field><name>customer_id</name><ascending>Y</ascending><case_sensitive>N</case_sensitive><collator_enabled>N</collator_enabled><collator_strength>0</collator_strength><presorted>N</presorted></field>
      <field><name>signup_date</name><ascending>Y</ascending><case_sensitive>N</case_sensitive><collator_enabled>N</collator_enabled><collator_strength>0</collator_strength><presorted>N</presorted></field>
    </fields>
    <attributes/>
    <GUI><xloc>280</xloc><yloc>260</yloc></GUI>
  </transform>

  <transform>
    <name>Unique customers</name>
    <type>Unique</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <count_rows>N</count_rows>
    <count_field/>
    <reject_duplicate_row>N</reject_duplicate_row>
    <error_description/>
    <fields>
      <field><name>customer_id</name><case_insensitive>N</case_insensitive></field>
    </fields>
    <attributes/>
    <GUI><xloc>480</xloc><yloc>260</yloc></GUI>
  </transform>

  <transform>
    <name>Filter valid customers</name>
    <type>FilterRows</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <compare>
      <condition>
        <conditions/>
        <function>IS NOT NULL</function>
        <leftvalue>customer_id</leftvalue>
        <negated>N</negated>
        <operator>-</operator>
      </condition>
    </compare>
    <send_false_to/>
    <send_true_to>Normalize city</send_true_to>
    <attributes/>
    <GUI><xloc>680</xloc><yloc>260</yloc></GUI>
  </transform>

  <transform>
    <name>Normalize city</name>
    <type>ValueMapper</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <field_to_use>city</field_to_use>
    <target_field>city</target_field>
    <non_match_default>Unknown</non_match_default>
    <fields>
      <field><source_value>CASABLANCA</source_value><target_value>Casablanca</target_value></field>
      <field><source_value>RABAT</source_value><target_value>Rabat</target_value></field>
      <field><source_value>MARRAKECH</source_value><target_value>Marrakech</target_value></field>
      <field><source_value>FES</source_value><target_value>Fes</target_value></field>
      <field><source_value>FEZ</source_value><target_value>Fes</target_value></field>
      <field><source_value>TANGIER</source_value><target_value>Tangier</target_value></field>
      <field><source_value>TANGER</source_value><target_value>Tangier</target_value></field>
      <field><source_value>AGADIR</source_value><target_value>Agadir</target_value></field>
    </fields>
    <attributes/>
    <GUI><xloc>880</xloc><yloc>260</yloc></GUI>
  </transform>

  <transform>
    <name>Default email</name>
    <type>IfNull</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <replaceAllByValue/>
    <replaceAllMask/>
    <selectFields>Y</selectFields>
    <selectValuesType>N</selectValuesType>
    <setEmptyStringAll>N</setEmptyStringAll>
    <valuetypes/>
    <fields>
      <field>
        <name>email</name>
        <value>unknown@unknown.com</value>
        <mask/>
        <set_empty_string>N</set_empty_string>
      </field>
    </fields>
    <attributes/>
    <GUI><xloc>1080</xloc><yloc>260</yloc></GUI>
  </transform>

  <transform>
    <name>Add customer_key</name>
    <type>Sequence</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <valuename>customer_key</valuename>
    <use_database>N</use_database>
    <use_counter>Y</use_counter>
    <counter_name/>
    <start_at>1</start_at>
    <increment_by>1</increment_by>
    <max_value>9999999</max_value>
    <attributes/>
    <GUI><xloc>1280</xloc><yloc>260</yloc></GUI>
  </transform>

  <transform>
    <name>Select customer fields</name>
    <type>SelectValues</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <fields>
      <field><name>customer_key</name><rename>customer_key</rename><length>-2</length><precision>-2</precision></field>
      <field><name>customer_id</name><rename>customer_id_src</rename><length>-2</length><precision>-2</precision></field>
      <field><name>customer_name</name><rename>customer_name</rename><length>-2</length><precision>-2</precision></field>
      <field><name>email</name><rename>email</rename><length>-2</length><precision>-2</precision></field>
      <field><name>city</name><rename>city</rename><length>-2</length><precision>-2</precision></field>
      <field><name>country</name><rename>country</rename><length>-2</length><precision>-2</precision></field>
      <field><name>signup_date</name><rename>signup_date</rename><length>-2</length><precision>-2</precision></field>
      <field><name>segment</name><rename>segment</rename><length>-2</length><precision>-2</precision></field>
    </fields>
    <select_unspecified>N</select_unspecified>
    <attributes/>
    <GUI><xloc>1480</xloc><yloc>260</yloc></GUI>
  </transform>

  <transform>
    <name>Write dim_customer</name>
    <type>TableOutput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <commit>1000</commit>
    <connection>DuckDB_Lab1</connection>
    <fields/>
    <ignore_errors>N</ignore_errors>
    <only_when_have_rows>N</only_when_have_rows>
    <partitioning_daily>N</partitioning_daily>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_monthly>Y</partitioning_monthly>
    <return_keys>N</return_keys>
    <schema>warehouse</schema>
    <specify_fields>N</specify_fields>
    <table>dim_customer</table>
    <tablename_in_field>N</tablename_in_field>
    <tablename_in_table>Y</tablename_in_table>
    <truncate>N</truncate>
    <use_batch>Y</use_batch>
    <attributes/>
    <GUI><xloc>1680</xloc><yloc>260</yloc></GUI>
  </transform>

  <!-- ══════════════════════════════════════════════════════════
       DIM_PRODUCT — StreamLookup for category (avoids DBLookup issues)
       y=460
       ══════════════════════════════════════════════════════════ -->

  <!-- Main stream: products -->
  <transform>
    <name>Read products</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <connection>DuckDB_Lab1</connection>
    <sql>SELECT product_id, product_name, category_id, unit_price, cost_price, active_flag FROM staging.products WHERE product_id IS NOT NULL</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <attributes/>
    <GUI><xloc>80</xloc><yloc>460</yloc></GUI>
  </transform>

  <transform>
    <name>Filter valid products</name>
    <type>FilterRows</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <compare>
      <condition>
        <conditions/>
        <function>IS NOT NULL</function>
        <leftvalue>product_id</leftvalue>
        <negated>N</negated>
        <operator>-</operator>
      </condition>
    </compare>
    <send_false_to/>
    <send_true_to>Lookup category info</send_true_to>
    <attributes/>
    <GUI><xloc>280</xloc><yloc>460</yloc></GUI>
  </transform>

  <!-- Lookup stream: categories (read into memory) -->
  <transform>
    <name>Read categories</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <connection>DuckDB_Lab1</connection>
    <sql>SELECT category_id, category_name, department FROM staging.categories</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <attributes/>
    <GUI><xloc>280</xloc><yloc>360</yloc></GUI>
  </transform>

  <!-- StreamLookup: join products with categories on category_id -->
  <transform>
    <name>Lookup category info</name>
    <type>StreamLookup</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <from>Read categories</from>
    <input_sorted>N</input_sorted>
    <preserve_memory>Y</preserve_memory>
    <sorted_list>N</sorted_list>
    <integer_pair>N</integer_pair>
    <lookup>
      <key>
        <name>category_id</name>
        <field>category_id</field>
      </key>
      <value>
        <name>category_name</name>
        <rename>category_name</rename>
        <default/>
        <type>String</type>
      </value>
      <value>
        <name>department</name>
        <rename>department</rename>
        <default/>
        <type>String</type>
      </value>
    </lookup>
    <attributes/>
    <GUI><xloc>480</xloc><yloc>460</yloc></GUI>
  </transform>

  <transform>
    <name>Add product_key</name>
    <type>Sequence</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <valuename>product_key</valuename>
    <use_database>N</use_database>
    <use_counter>Y</use_counter>
    <counter_name/>
    <start_at>1</start_at>
    <increment_by>1</increment_by>
    <max_value>9999999</max_value>
    <attributes/>
    <GUI><xloc>680</xloc><yloc>460</yloc></GUI>
  </transform>

  <transform>
    <name>Select product fields</name>
    <type>SelectValues</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <fields>
      <field><name>product_key</name><rename>product_key</rename><length>-2</length><precision>-2</precision></field>
      <field><name>product_id</name><rename>product_id_src</rename><length>-2</length><precision>-2</precision></field>
      <field><name>product_name</name><rename>product_name</rename><length>-2</length><precision>-2</precision></field>
      <field><name>category_id</name><rename>category_id</rename><length>-2</length><precision>-2</precision></field>
      <field><name>category_name</name><rename>category_name</rename><length>-2</length><precision>-2</precision></field>
      <field><name>department</name><rename>department</rename><length>-2</length><precision>-2</precision></field>
      <field><name>unit_price</name><rename>unit_price</rename><length>-2</length><precision>-2</precision></field>
      <field><name>cost_price</name><rename>cost_price</rename><length>-2</length><precision>-2</precision></field>
      <field><name>active_flag</name><rename>active_flag</rename><length>-2</length><precision>-2</precision></field>
    </fields>
    <select_unspecified>N</select_unspecified>
    <attributes/>
    <GUI><xloc>880</xloc><yloc>460</yloc></GUI>
  </transform>

  <transform>
    <name>Write dim_product</name>
    <type>TableOutput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <commit>1000</commit>
    <connection>DuckDB_Lab1</connection>
    <fields/>
    <ignore_errors>N</ignore_errors>
    <only_when_have_rows>N</only_when_have_rows>
    <partitioning_daily>N</partitioning_daily>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_monthly>Y</partitioning_monthly>
    <return_keys>N</return_keys>
    <schema>warehouse</schema>
    <specify_fields>N</specify_fields>
    <table>dim_product</table>
    <tablename_in_field>N</tablename_in_field>
    <tablename_in_table>Y</tablename_in_table>
    <truncate>N</truncate>
    <use_batch>Y</use_batch>
    <attributes/>
    <GUI><xloc>1080</xloc><yloc>460</yloc></GUI>
  </transform>

  <!-- ══════════════════════════════════════════════════════════
       DIM_CHANNEL — Hop native transforms
       y=640
       ══════════════════════════════════════════════════════════ -->
  <transform>
    <name>Read channels</name>
    <type>TableInput</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <connection>DuckDB_Lab1</connection>
    <sql>SELECT DISTINCT channel FROM staging.orders WHERE channel IS NOT NULL ORDER BY channel</sql>
    <limit>0</limit>
    <lookup/>
    <execute_each_row>N</execute_each_row>
    <variables_active>N</variables_active>
    <lazy_conversion_active>N</lazy_conversion_active>
    <attributes/>
    <GUI><xloc>80</xloc><yloc>640</yloc></GUI>
  </transform>

  <transform>
    <name>Map channel_type</name>
    <type>ValueMapper</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <field_to_use>channel</field_to_use>
    <target_field>channel_type</target_field>
    <non_match_default>Unknown</non_match_default>
    <fields>
      <field><source_value>Online</source_value><target_value>Digital</target_value></field>
      <field><source_value>Store</source_value><target_value>Physical</target_value></field>
      <field><source_value>Partner</source_value><target_value>Indirect</target_value></field>
    </fields>
    <attributes/>
    <GUI><xloc>280</xloc><yloc>640</yloc></GUI>
  </transform>

  <transform>
    <name>Add channel_key</name>
    <type>Sequence</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <valuename>channel_key</valuename>
    <use_database>N</use_database>
    <use_counter>Y</use_counter>
    <counter_name/>
    <start_at>1</start_at>
    <increment_by>1</increment_by>
    <max_value>9999999</max_value>
    <attributes/>
    <GUI><xloc>480</xloc><yloc>640</yloc></GUI>
  </transform>

  <transform>
    <name>Select channel fields</name>
    <type>SelectValues</type>
    <description/>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <fields>
      <field><name>channel_key</name><rename>channel_key</rename><length>-2</length><precision>-2</precision></field>
      <field><name>channel</name><rename>channel_name</rename><length>-2</length><precision>-2</precision></field>
      <field><name>channel_type</name><rename>channel_type</rename><length>-2</length><precision>-2</precision></field>
    </fields>
    <select_unspecified>N</select_unspecified>
    <attributes/>
    <GUI><xloc>680</xloc><yloc>640</yloc></GUI>
  </transform>

  <transform>
    <name>Write dim_channel</name>
    <type>TableOutput</type>
    <description/>
    <distribute>Y</distribute>
